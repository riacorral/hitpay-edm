NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key for encrypting Loops credentials at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

